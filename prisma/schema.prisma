generator client {
  provider = "prisma-client-js"
  engineType = "library"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}


datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   // ADMIN, DOCTOR, NURSE, RECEPTIONIST, PHARMACIST, LAB_TECH
  surgeries Surgery[] @relation("Surgeon")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  visitsConsulted Visit[] @relation("DoctorVisits")
  authorizedBills Bill[]  @relation("BillAuthorizer")


  @@index([email])
}


model Patient {
  id        String   @id @default(cuid())
  uhid      String   @unique // MH-10001
  name      String
  phone     String?
  age       Int
  gender    String
  address   String?
  
  // Compliance Fields
